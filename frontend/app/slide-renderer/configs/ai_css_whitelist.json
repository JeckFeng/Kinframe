{
  "version": "v0.1",
  "mode": "css_variables_only",
  "cssVariables": {
    "color": [
      "--kf-background-color",
      "--kf-text-color",
      "--kf-accent-color"
    ],
    "opacity": [
      "--kf-bg-overlay-opacity",
      "--kf-caption-opacity",
      "--kf-timeline-opacity"
    ],
    "shadow": [
      "--kf-photo-shadow",
      "--kf-caption-shadow"
    ],
    "typography": [
      "--kf-caption-font-family",
      "--kf-caption-font-size",
      "--kf-caption-font-weight",
      "--kf-caption-letter-spacing",
      "--kf-caption-line-height",
      "--kf-meta-font-size"
    ],
    "radius": [
      "--kf-photo-radius",
      "--kf-panel-radius"
    ]
  },
  "variablePrefix": "--kf-",
  "forbiddenCapabilities": [
    "@import",
    "@font-face",
    "url(http",
    "url(https",
    "javascript:",
    "expression(",
    "behavior"
  ],
  "forbiddenSelectors": [
    "html",
    "body",
    "#app",
    "*",
    "script",
    "iframe"
  ]
}
