{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kinframe.local/schemas/slide_design.schema.json",
  "title": "KinFrame v0.3 Slide Design",
  "type": "object",
  "additionalProperties": false,
  "required": ["photoId", "templateId", "templateParams", "layers", "styleTokens", "renderPolicy"],
  "properties": {
    "photoId": {
      "type": "string",
      "minLength": 1
    },
    "templateId": {
      "type": "string",
      "enum": [
        "cinematic_fullscreen", "warm_memory", "minimal_white",
        "poetic_landscape", "magazine_left", "gallery_center",
        "dark_exhibition", "pet_portrait"
      ]
    },
    "templateParams": {
      "type": "object"
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "zIndex"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["shape", "image", "text", "timeline", "background", "mask", "texture", "vignette"]
          },
          "role": { "type": "string" },
          "source": { "type": "string" },
          "content": { "type": "string" },
          "label": { "type": "string" },
          "timeText": { "type": "string" },
          "locationText": { "type": "string" },
          "fit": { "type": "string" },
          "zIndex": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "rect": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y", "width", "height"],
            "properties": {
              "x": { "type": "number", "minimum": 0, "maximum": 1 },
              "y": { "type": "number", "minimum": 0, "maximum": 1 },
              "width": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
              "height": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
            }
          },
          "style": {
            "type": "object"
          },
          "fill": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["solid", "linearGradient", "radialGradient", "imageBlur", "noise"]
              },
              "color": { "type": "string" },
              "angle": { "type": "number" },
              "center": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                }
              },
              "radius": { "type": "number" },
              "stops": {
                "type": "array",
                "minItems": 2,
                "maxItems": 5,
                "items": {
                  "type": "object",
                  "required": ["color", "opacity", "position"],
                  "properties": {
                    "color": { "type": "string" },
                    "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
                    "position": { "type": "number", "minimum": 0, "maximum": 1 }
                  }
                }
              }
            }
          },
          "shadow": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "type": {
                "type": "string",
                "enum": ["soft", "dramatic", "glow", "inner"]
              },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "blur": { "type": "number", "maximum": 120 },
              "spread": { "type": "number" },
              "color": { "type": "string" },
              "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          "presetRef": { "type": "string" },
          "blendMode": {
            "type": "string",
            "enum": ["overlay", "multiply", "screen", "normal"]
          },
          "opacity": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "not": {
          "anyOf": [
            { "required": ["html"] },
            { "required": ["script"] }
          ]
        }
      }
    },
    "styleTokens": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^--kf-"
      }
    },
    "renderPolicy": {
      "type": "object",
      "additionalProperties": true,
      "required": ["allowHtml", "allowJavaScript"],
      "properties": {
        "mode": { "type": "string" },
        "allowHtml": { "const": false },
        "allowJavaScript": { "const": false }
      }
    },
    "aiMeta": {
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "promptVersion": { "type": "string" },
        "generatedAt": { "type": "string" }
      }
    }
  }
}
