APP_ENV=development
APP_SECRET_KEY=change-me

DATABASE_URL=postgresql+psycopg://kinframe:change-me@localhost:15432/kinframe
POSTGRES_PORT=15432
REDIS_URL=redis://localhost:16379/0
REDIS_PORT=16379

MINIO_ENDPOINT=localhost:19000
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
MINIO_ACCESS_KEY=kinframe
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=kinframe-photos

CADDY_HTTP_PORT=18080

MAX_UPLOAD_SIZE_MB=100

SESSION_COOKIE_NAME=kinframe_session
SESSION_EXPIRE_DAYS=30

BACKEND_PORT=18000
FRONTEND_PORT=3000
KINFRAME_API_PROXY=http://127.0.0.1:18000

BACKUP_DIR=data/backups
BACKUP_INCLUDE_ENV=0

WORKER_ENABLED=1
WORKER_POLL_INTERVAL_SECONDS=5
PHOTO_JOB_MAX_ATTEMPTS=3
PHOTO_JOB_RETRY_DELAY_SECONDS=30

THUMBNAIL_SIZE_PX=512
PREVIEW_MAX_SIZE_PX=2048
HEIC_STRATEGY=reject

# ── Geocoding ────────────────────────────────────────────────────
# Provider: nominatim | amap | noop (noop disables geocoding)
GEOCODING_ENABLED=false
GEOCODING_PROVIDER=nominatim
NOMINATIM_ENDPOINT=https://nominatim.openstreetmap.org
# AMAP_API_KEY=your_amap_web_api_key
GEOCODING_TIMEOUT_SECONDS=30
GEOCODING_MAX_RETRIES=2
GEOCODING_RATE_LIMIT_PER_SECOND=1.0

# ── AI ───────────────────────────────────────────────────────────
AI_ENABLED=false
# OLLAMA_ENDPOINT=http://localhost:11434
# OLLAMA_VISION_MODEL=qwen3-vl:8b
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_MODEL=deepseek-v4-flash
AI_REQUEST_TIMEOUT_SECONDS=500
AI_MAX_RETRIES=1
